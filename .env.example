# Server Configuration
SERVER_PORT=5001

# Database Configuration
DB_DRIVER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=taskdb
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=100
DB_MAX_IDLE_CONNS=10

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRATION=1440

# AI Terminal (Web PTY) Configuration
# 警告：终端以服务器进程身份(root)打开 shell，仅管理员可用。生产环境请谨慎启用。
TERMINAL_ENABLED=true
TERMINAL_SHELL=bash
# 会话初始工作目录，留空则继承服务器进程工作目录(项目根目录)
TERMINAL_WORKDIR=
